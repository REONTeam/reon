{% extends "main.twig" %}
{% set nav_item = "games" %}

{% block title %}Pok&eacute;mon - BXT Save Converter{% endblock %}

{% block head %}
<link href="/css/saveconverter.css?v=bxt-save-converter-v4" rel="stylesheet">
<link href="/css/pokecrystal-pages.css?v=pokecrystal-pages-v41" rel="stylesheet">
<style>
    @font-face {
        font-family: "PokeCrystalInline";
        src: url("/fonts/Crystal/pokecrystal.ttf?v=pokecrystal-font-v5") format("truetype");
        font-weight: 400;
        font-style: normal;
    }
    .save-converter-page,
    .save-converter-page * {
        font-family: "PokeCrystalInline", "PokeCrystal", monospace !important;
        font-weight: 400 !important;
    }
</style>
{% endblock %}

{% block content %}
<div class="save-converter-page">
    <h1 class="trade-corner-title">&#xFF22;&#xFF38;&#xFF34;&#x3000;&#xFF33;&#xFF21;&#xFF36;&#xFF25;&#x3000;&#xFF23;&#xFF2F;&#xFF2E;&#xFF36;&#xFF25;&#xFF32;&#xFF34;&#xFF25;&#xFF32;</h1>

    <div class="save-converter-card">
        <p class="save-converter-note">
            Conversion runs entirely in your browser.
        </p>

        <div class="save-converter-row">
            <div class="save-converter-label">Original <code>.sav</code> file</div>
            <div class="save-file-picker">
                <input id="save-file-input" class="save-file-input" type="file" accept=".sav,application/octet-stream" aria-label="Choose .sav file">
                <label for="save-file-input" id="save-file-input-label" class="save-file-button">Choose File</label>
                <div id="save-file-name" class="save-file-name">No file chosen</div>
            </div>
        </div>

        <div class="save-converter-row">
            <div class="save-converter-label">Language</div>
            <div class="save-language-grid" id="save-language-grid" role="radiogroup" aria-label="Save language">
                <label><input type="radio" name="save-lang" value="E"> English</label>
                <label><input type="radio" name="save-lang" value="F"> French</label>
                <label><input type="radio" name="save-lang" value="D"> German</label>
                <label><input type="radio" name="save-lang" value="S"> Spanish</label>
                <label><input type="radio" name="save-lang" value="I"> Italian</label>
            </div>
        </div>

        <div class="save-converter-actions">
            <button id="save-convert-btn" class="save-convert-btn" type="button">Convert</button>
        </div>

        <div class="save-converter-status" id="save-converter-status" aria-live="polite">
            Ready.
        </div>
    </div>
</div>
{% endblock %}

{% block body %}
<script src="/js/saveconverter.js?v=bxt-save-converter-v3"></script>
{% endblock %}






