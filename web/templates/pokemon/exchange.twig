{% extends "main.twig" %}

{% block title %}PokÃ©mon - Trade Corner{% endblock %}
{% block head %}
    <link href="/css/pokecrystal-pages.css?v=pokecrystal-pages-v41" rel="stylesheet">
{% endblock %}
{% block content %}
    <div class="exchange-page">
    {% set trade_asset_rev = 'trade-card-ui-v4' %}

    <h1 class="trade-corner-title">ï¼´ï¼²ï¼¡ï¼¤ï¼¥ã€€ï¼£ï¼¯ï¼²ï¼®ï¼¥ï¼²</h1>
    {% set current_region_filter = region_filter|default('global') %}
    <div class="trade-region-filter-wrap">
        <select id="trade-region-filter" class="trade-region-filter" aria-label="{{'region.text'|trans}}">
            <option value="global"{% if current_region_filter == 'global' %} selected{% endif %}>{{'region.global'|trans}}</option>
            <option value="int"{% if current_region_filter == 'int' %} selected{% endif %}>{{'region.international'|trans}}</option>
            <option value="j"{% if current_region_filter == 'j' %} selected{% endif %}>{{'region.short.j'|trans}} : {{'region.country.j'|trans}}</option>
            <option value="eng"{% if current_region_filter == 'eng' %} selected{% endif %}>ENG : All</option>
            <option value="e"{% if current_region_filter == 'e' %} selected{% endif %}>{{'region.short.e'|trans}} : {{'region.country.e'|trans}}</option>
            <option value="p"{% if current_region_filter == 'p' %} selected{% endif %}>{{'region.short.p'|trans}} : {{'region.country.p'|trans}}</option>
            <option value="u"{% if current_region_filter == 'u' %} selected{% endif %}>{{'region.short.u'|trans}} : {{'region.country.u'|trans}}</option>
            <option value="f"{% if current_region_filter == 'f' %} selected{% endif %}>{{'region.short.f'|trans}} : {{'region.country.f'|trans}}</option>
            <option value="d"{% if current_region_filter == 'd' %} selected{% endif %}>{{'region.short.d'|trans}} : {{'region.country.d'|trans}}</option>
            <option value="i"{% if current_region_filter == 'i' %} selected{% endif %}>{{'region.short.i'|trans}} : {{'region.country.i'|trans}}</option>
            <option value="s"{% if current_region_filter == 's' %} selected{% endif %}>{{'region.short.s'|trans}} : {{'region.country.s'|trans}}</option>
        </select>
    </div>
    <div class="trade-search-wrap">
        <input
            id="trade-search-input"
            class="trade-search-input"
            type="text"
            placeholder="Search..."
            aria-label="Search trades"
            autocomplete="off"
            spellcheck="false"
        >
    </div>

    <div class="trade-corner-list">
    {% for trade in trades %}
    <div class="crystal-trade-slot" data-game-region="{{ trade.game_region|lower }}">
    <div class="trade-warning{% if not trade.trade_warning_key %} trade-warning-empty{% endif %}">
        {% if trade.trade_warning_key %}
            {{ trade.trade_warning_key|trans({'%game_id%': trade.trade_warning_game_id}) }}
        {% else %}
            &nbsp;
        {% endif %}
    </div>
    <div class="crystal-trade">
        <div class="marks-panel">
        {% set region_code_tmpl = 'region.short.' ~ trade.game_region %}
        {% set region_lang_tmpl = 'region.language.' ~ trade.game_region %}
        <abbr class="region" title="{{region_lang_tmpl|trans}}">{{region_code_tmpl|trans}}</abbr>
            {% if trade.pokemon.pokerus %}
                {% if trade.pokemon.pokerus.cured %}
                <abbr class="pokerus-cured-text" title="{{'pokemon.pokerus.cured'|trans}}">&#11044;</abbr>
                {% else %}
                <abbr class="pokerus-infected-text" title="{{'pokemon.pokerus.infected'|trans}}"><sup>P</sup><sub>K</sub>RS</abbr>
                {% endif %}
                <br>
            {% endif %}
            {% if trade.pokemon.is_shiny %}<span class="shiny-mark" title="{{'pokemon.shiny'|trans}}"></span>{% endif %}
        </div>
        <div class="trade-offer {% if trade.pokemon.is_shiny %}shiny{% endif %}">
            <!-- DVs {{trade.pokemon.iv.hp}}/{{trade.pokemon.iv.attack}}/{{trade.pokemon.iv.defense}}/{{trade.pokemon.iv.special}}/{{trade.pokemon.iv.speed}} -->
            <!-- EVs {{trade.pokemon.ev.hp}}/{{trade.pokemon.ev.attack}}/{{trade.pokemon.ev.defense}}/{{trade.pokemon.ev.special}}/{{trade.pokemon.ev.speed}} -->
            <!-- Shiny {{trade.pokemon.is_shiny}} -->
            <div class="media-area">
                {% set anim_variant = trade.pokemon.is_shiny ? 'Shiny' : 'Normal' %}
                {% set static_path = '/images/crystal/battle_anims_first_frame/' ~ anim_variant ~ '/' ~ trade.offer.id ~ '.png?v=' ~ trade_asset_rev %}
                {% set anim_path = '/images/crystal/battle_anims/' ~ anim_variant ~ '/' ~ trade.offer.id ~ '.gif?v=' ~ trade_asset_rev %}
                <img class="sprite-pokemon sprite-pokemon-hoveranim" src="{{static_path}}" data-static-src="{{static_path}}" data-anim-src="{{anim_path}}" alt="{{trade.offer.name|trans}}" loading="lazy">
                <br>
                <span class="level-label">{{'pokemon.level'|trans}}</span>
                <span class="offer-level">{{trade.pokemon.level}}</span>
                <span class="offer-gender gender-{{trade.offer.gender}}" title="{{trade.offer.gender|trans}}">{{trade.offer.gender_symbol}}</span>
                <br>
            </div>
            
            <div class="offer-details">
                <span class="offer-species">{{trade.offer.name|trans}}</span>
                <br> 
                <span class="label">{{'pokemon.name'|trans}}</span>
                <span class="offer-name">{{trade.pokemon.name}}</span>
                <br> 
                <span class="label">{{'pokemon.offerer'|trans}}</span>
                <span class="offer-offerer">{{trade.player_name}}</span>
                <br>
                <span class="label">{{'pokemon.item'|trans}}</span>
                <span class="offer-item">{% if trade.pokemon.item %}{{trade.pokemon.item.name}}{% endif %}</span>
    
            </div>
        </div>
        <hr class="trade-separator">
        <div class="trade-request">
            <span class="wanted-label">{{'pokemon.wanted'|trans}}</span>
            {# Only show gender when requested and not Nidoran #}
            {% if trade.request.gender %}
            <span class="request-gender gender-{{trade.request.gender}}" title="{{trade.request.gender|trans}}">{{trade.request.gender_symbol}}</span>
            {% endif %}
            <span class="request-species">{{trade.request.name}}</span>
        </div>
    
    </div>
    <div
        class="trade-remaining"
        data-exchange-created-epoch="{{ trade.exchange_created_epoch|default(0) }}"
        data-exchange-expire-epoch="{{ trade.exchange_expire_epoch|default(0) }}"
        data-exchange-lifetime-seconds="{{ trade.exchange_lifetime_seconds|default(604800) }}"
    >
        00h : 00m : 00s
    </div>
    </div>
    {% endfor %}
    </div>
    <div id="trade-no-results" class="trade-no-results crystal-empty-message"{% if trades|length > 0 %} style="display:none"{% endif %}>
        No results found.
    </div>
    </div>

{% endblock %}

{% block body %}
<script src="/js/crystal-search-ui.js?v=crystal-search-ui-v7"></script>
<script src="/js/exchange-hover-anim.js?v=exchange-hover-anim-v2"></script>
{% endblock %}





