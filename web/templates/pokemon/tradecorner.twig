{% extends "main.twig" %}

{% block title %}Pok&eacute;mon - Trade Corner{% endblock %}
{% block head %}
    <link href="/css/pokecrystal-pages.css?v=pokecrystal-pages-v50" rel="stylesheet">
    <style>
        @font-face {
            font-family: "PokeCrystalInline";
            src: url("/fonts/Crystal/pokecrystal.ttf?v=pokecrystal-font-v5") format("truetype");
            font-weight: 400;
            font-style: normal;
        }
        .exchange-page,
        .exchange-page * {
            font-family: "PokeCrystalInline", "PokeCrystal", monospace !important;
            font-weight: 400 !important;
        }
    </style>
{% endblock %}
{% block content %}
    <div class="exchange-page">
    {% set trade_asset_rev = 'trade-card-ui-v13' %}

    <h1 class="trade-corner-title">&#xFF34;&#xFF32;&#xFF21;&#xFF24;&#xFF25;&#x3000;&#xFF23;&#xFF2F;&#xFF32;&#xFF2E;&#xFF25;&#xFF32;</h1>
    {% set current_region_filter = region_filter|default('global') %}
    <div class="trade-region-filter-wrap">
        <select id="trade-region-filter" class="trade-region-filter" aria-label="{{'region.text'|trans}}">
            <option value="global"{% if current_region_filter == 'global' %} selected{% endif %}>&#xFF27;&#xFF2C;&#xFF2F;&#xFF22;&#xFF21;&#xFF2C;</option>
            <option value="int"{% if current_region_filter == 'int' %} selected{% endif %}>&#xFF29;&#xFF2E;&#xFF34;&#xFF25;&#xFF32;&#xFF2E;&#xFF21;&#xFF34;&#xFF29;&#xFF2F;&#xFF2E;&#xFF21;&#xFF2C;</option>
            <option value="j"{% if current_region_filter == 'j' %} selected{% endif %}>&#xFF2A;&#xFF30;&#xFF2E;:JAPAN</option>
            <option value="eng"{% if current_region_filter == 'eng' %} selected{% endif %}>&#xFF25;&#xFF2E;&#xFF27;:ALL</option>
            <option value="e"{% if current_region_filter == 'e' %} selected{% endif %}>&#xFF25;&#xFF2E;&#xFF27;:USA</option>
            <option value="p"{% if current_region_filter == 'p' %} selected{% endif %}>&#xFF25;&#xFF2E;&#xFF27;:EUROPE</option>
            <option value="u"{% if current_region_filter == 'u' %} selected{% endif %}>&#xFF25;&#xFF2E;&#xFF27;:AUSTRALIA</option>
            <option value="f"{% if current_region_filter == 'f' %} selected{% endif %}>&#xFF26;&#xFF32;&#xFF21;:FRANCE</option>
            <option value="d"{% if current_region_filter == 'd' %} selected{% endif %}>&#xFF27;&#xFF25;&#xFF32;:GERMANY</option>
            <option value="i"{% if current_region_filter == 'i' %} selected{% endif %}>&#xFF29;&#xFF34;&#xFF21;:ITALY</option>
            <option value="s"{% if current_region_filter == 's' %} selected{% endif %}>&#xFF33;&#xFF30;&#xFF21;:SPAIN</option>
        </select>
    </div>
    <div class="trade-search-wrap">
        <div id="trade-search-tokenized" class="trade-search-tokenized" role="group" aria-label="Search trades">
            <div id="trade-search-chip-list" class="trade-search-chip-list" aria-live="polite"></div>
            <input
                id="trade-search-tail-input"
                class="trade-search-tail-input trade-search-input"
                type="text"
                placeholder="Search..."
                aria-label="Search trades"
                autocomplete="off"
                spellcheck="false"
            >
        </div>
        <input
            id="trade-search-input"
            class="trade-search-input-hidden"
            type="text"
            autocomplete="off"
            spellcheck="false"
            tabindex="-1"
            aria-hidden="true"
        >
    </div>
    <div id="trade-search-tag-pills" class="trade-search-tag-pills" data-locale="{{ curr_locale|default('en')|e('html_attr') }}" aria-label="Search tags">
        <span class="trade-search-tag-label">Tags:</span>
        <button class="trade-search-tag-pill" type="button" data-tag-field="species">SPECIES:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="level">LEVEL:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="gender">GENDER:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="shiny">SHINY:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="name">NAME:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="ot">OT:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="item">ITEM:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="offerer">OFFERER:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="language">LANGUAGE:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="country">COUNTRY:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="pokerus">POK&eacute;RUS:</button>
        <button class="trade-search-tag-pill" type="button" data-tag-field="wanted">WANTED:</button>
    </div>
    <div class="trade-size-wrap">
        <label class="trade-size-label" for="trade-size-btn-1">Zoom:</label>
        <div class="trade-size-buttons" role="group" aria-label="Card size">
            <button id="trade-size-btn-1" class="trade-size-btn" type="button" data-trade-size="1">1x</button>
            <button class="trade-size-btn" type="button" data-trade-size="2">2x</button>
        </div>
    </div>

    <div class="trade-corner-list">
    {% for trade in trades %}
    {% set offer_species_label = trade.pokemon.species.name|default(trade.offer.name) %}
    {% set request_species_label = trade.request.name %}
    <div
        class="crystal-trade-slot"
        data-game-region="{{ trade.game_region|lower }}"
        data-offer-species-search="{{ trade.offer.search_names|default('') }}"
        data-request-species-search="{{ trade.request.search_names|default('') }}"
    >
    <div class="trade-warning{% if not trade.trade_warning_key %} trade-warning-empty{% endif %}">
        {% if trade.trade_warning_key %}
            {% set trade_warning_text = trade.trade_warning_key|trans({'%game_id%': trade.trade_warning_game_id}) %}
            {{ trade_warning_text|replace({'вљ пёЏ': '!', 'вљ ': '!', 'ГўЕЎВ ГЇВёВЏ': '!', 'ГўЕЎВ ': '!'}) }}
        {% else %}
            &nbsp;
        {% endif %}
    </div>
    <div class="crystal-trade">
        <img class="trade-card-bg" src="/images/crystal/TradeCornerCard.png?v={{ trade_asset_rev }}" alt="" loading="lazy">
        <div class="trade-offer {% if trade.pokemon.is_shiny %}shiny{% endif %}">
            <!-- DVs {{trade.pokemon.iv.hp}}/{{trade.pokemon.iv.attack}}/{{trade.pokemon.iv.defense}}/{{trade.pokemon.iv.special}}/{{trade.pokemon.iv.speed}} -->
            <!-- EVs {{trade.pokemon.ev.hp}}/{{trade.pokemon.ev.attack}}/{{trade.pokemon.ev.defense}}/{{trade.pokemon.ev.special}}/{{trade.pokemon.ev.speed}} -->
            <!-- Shiny {{trade.pokemon.is_shiny}} -->
            <div class="media-area">
                {% set anim_variant = trade.pokemon.is_shiny ? 'Shiny' : 'Normal' %}
                {% set static_path = '/images/crystal/battle_anims_first_frame/' ~ anim_variant ~ '/' ~ trade.offer.id ~ '.png?v=' ~ trade_asset_rev %}
                {% set anim_path = '/images/crystal/battle_anims/' ~ anim_variant ~ '/' ~ trade.offer.id ~ '.gif?v=' ~ trade_asset_rev %}
                <img class="sprite-pokemon sprite-hoveranim" src="{{static_path}}" data-static-src="{{static_path}}" data-anim-src="{{anim_path}}" alt="{{offer_species_label}}" loading="lazy">
                <div class="offer-region-line" title="{{ trade.region_hover_text|default('') }}">{{ trade.region_display_fullwidth|default('') }}</div>
                {% if trade.pokemon.pokerus %}
                    <img class="offer-pkrs-tag" src="/images/crystal/TradeCornerPKRSTag.png?v={{ trade_asset_rev }}" alt="" loading="lazy">
                {% endif %}
                <div class="offer-pokerus-line{% if trade.pokemon.pokerus %} pokerus-active{% endif %}">
                    {% if trade.pokemon.pokerus %}
                        {% if trade.pokemon.pokerus.cured %}
                            <span class="offer-pokerus-cured" title="{{'pokemon.pokerus.cured'|trans}}">&#x25CF;</span>
                        {% else %}
                            <span class="offer-pokerus-infected" title="{{'pokemon.pokerus.infected'|trans}}">&#x1D3E;&#x2096;&#x1D63;&#x209B;</span>
                        {% endif %}
                    {% else %}
                        &nbsp;
                    {% endif %}
                </div>
                <div class="offer-after-pokerus-line">&nbsp;</div>
            </div>
            
            <div class="offer-details">
                {% set level_marker = ('pokemon.level'|trans)|upper|replace({' ': '', ':': '', ':': ''})|trim %}
                {% if level_marker == '' %}{% set level_marker = 'L' %}{% endif %}
                <div class="offer-species-line">
                    <span class="offer-species-fixed">{{ offer_species_label }}</span>
                    <span class="offer-inline-space">&nbsp;</span>
                    <span class="offer-level-fixed">
                        {% if trade.pokemon.level > 99 %}
                            {{ trade.pokemon.level }}
                        {% else %}
                            <span class="offer-level-prefix">&#xFF1A;{{ level_marker|slice(0, 1) }}</span><span class="offer-level-digits">{{ trade.pokemon.level }}</span>
                        {% endif %}
                    </span>
                    <span class="offer-inline-space">&nbsp;</span>
                    <span class="offer-gender-fixed"{% if trade.offer.gender %} title="{{trade.offer.gender|trans}}"{% endif %}>{% if trade.offer.gender_symbol %}{{ trade.offer.gender_symbol }}{% else %}&nbsp;{% endif %}</span>
                    <span class="offer-inline-space">&nbsp;</span>
                    <span class="offer-shiny-fixed"{% if trade.pokemon.is_shiny %} title="{{'pokemon.shiny'|trans}}"{% endif %}>{% if trade.pokemon.is_shiny %}&#x2728;{% else %}&nbsp;{% endif %}</span>
                    <span class="offer-tail-space">&nbsp;</span>
                </div>
                <div class="offer-species-gap">&nbsp;</div>
                <div class="offer-row offer-row-name">
                    <span class="label">{{'pokemon.name'|trans}}</span>
                    <span class="offer-name">{{trade.pokemon.name}}</span>
                </div>
                <div class="offer-row-gap">&nbsp;</div>
                <div class="offer-row offer-row-ot">
                    <span class="label">OT</span>
                    <span class="offer-ot">{{trade.pokemon.ot_name|default(trade.player_name)}}</span>
                </div>
                <div class="offer-row-gap">&nbsp;</div>
                <div class="offer-row offer-row-item">
                    <span class="label">{{'pokemon.item'|trans}}</span>
                    <span class="offer-item">{% if trade.pokemon.item %}{{trade.pokemon.item.name}}{% endif %}</span>
                </div>
                <div class="offer-row-gap">&nbsp;</div>
                <div class="offer-row offer-row-offerer">
                    <span class="label">{{'pokemon.offerer'|trans}}</span>
                    <span class="offer-offerer">{{trade.player_name}}</span>
                </div>
            </div>
        </div>
        <hr class="trade-separator">
        <div class="trade-request">
            <span class="trade-request-text">
                <span class="wanted-label">{{'pokemon.wanted'|trans}}</span>
                <span class="wanted-gap-before-gender">&nbsp;</span>
                <span class="wanted-gender-char{% if not trade.request.gender_symbol %} wanted-gender-empty{% endif %}"{% if trade.request.gender %} title="{{trade.request.gender|trans}}"{% endif %}>{% if trade.request.gender_symbol %}{{ trade.request.gender_symbol }}{% else %}&nbsp;{% endif %}</span>
                <span class="wanted-gap-after-gender{% if not trade.request.gender_symbol %} wanted-gap-no-gender{% endif %}">{% if trade.request.gender_symbol %}&nbsp;{% else %}&nbsp;&nbsp;{% endif %}</span>
                <span class="request-species">{{ request_species_label }}</span>
            </span>
            {% set wanted_menu_icon_name = trade.request.menu_icon|default('ICON_MONSTER') %}
            {% set wanted_menu_anim_path = '/images/crystal/menu_anims/' ~ wanted_menu_icon_name ~ '.gif?v=' ~ trade_asset_rev %}
            {% set wanted_menu_fallback_path = '/images/crystal/menu_anims/ICON_MONSTER.gif?v=' ~ trade_asset_rev %}
            <img
                class="wanted-menu-sprite sprite-hoveranim"
                src="{{ wanted_menu_anim_path }}"
                data-anim-src="{{ wanted_menu_anim_path }}"
                data-static-src=""
                data-fallback-src="{{ wanted_menu_fallback_path }}"
                alt="{{ request_species_label }}"
                loading="lazy"
            >
        </div>
        <div class="trade-request-bottom-spacer">&nbsp;</div>
    
    </div>
    <div
        class="trade-remaining"
        data-exchange-created-epoch="{{ trade.exchange_created_epoch|default(0) }}"
        data-exchange-expire-epoch="{{ trade.exchange_expire_epoch|default(0) }}"
        data-exchange-lifetime-seconds="{{ trade.exchange_lifetime_seconds|default(604800) }}"
    >
        00h:00m:00s
    </div>
    </div>
    {% endfor %}
    </div>
    <div id="trade-no-results" class="trade-no-results crystal-empty-message"{% if trades|length > 0 %} style="display:none"{% endif %}>
        No results found.
    </div>
    </div>

{% endblock %}

{% block body %}
<script>
(function () {
    "use strict";

    function findTradeCornerAnchor() {
        return document.querySelector(
            "header.navbar.container-xxl, header.navbar, main#content.container-xxl, #content.container-xxl, .container-xxl"
        );
    }

    function applyTradeCornerSideBackgroundVars() {
        var anchor = findTradeCornerAnchor();
        if (!anchor) {
            return;
        }
        var rect = anchor.getBoundingClientRect();
        var sideLeft = Math.max(0, Math.round(rect.left));
        var sideRight = Math.max(0, Math.round(window.innerWidth - rect.right));
        document.documentElement.style.setProperty("--trade-corner-nav-side-left", sideLeft + "px");
        document.documentElement.style.setProperty("--trade-corner-nav-side-right", sideRight + "px");
    }

    function initTradeCornerSideBackgrounds() {
        document.body.classList.add("trade-corner-theme");
        applyTradeCornerSideBackgroundVars();
        window.addEventListener("resize", applyTradeCornerSideBackgroundVars, { passive: true });
        window.addEventListener("load", applyTradeCornerSideBackgroundVars, { passive: true });
        if (document.fonts && typeof document.fonts.ready === "object") {
            document.fonts.ready.then(applyTradeCornerSideBackgroundVars);
        }
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initTradeCornerSideBackgrounds);
    } else {
        initTradeCornerSideBackgrounds();
    }
})();
</script>
<script src="/js/crystal-search-ui.js?v=crystal-search-ui-v8"></script>
<script src="/js/exchange-hover-anim.js?v=exchange-hover-anim-v16"></script>
{% endblock %}






