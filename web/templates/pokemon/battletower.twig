{% extends "main.twig" %}
{% set nav_item = "games" %}

{% block title %}Pok&eacute;mon - Battle Tower{% endblock %}

{% block head %}
<link href="/css/battle-tower.css?v=battle-tower-v24" rel="stylesheet">
<link href="/css/pokecrystal-pages.css?v=pokecrystal-pages-v41" rel="stylesheet">
<style>
    @font-face {
        font-family: "PokeCrystalInline";
        src: url("/fonts/Crystal/pokecrystal.ttf?v=pokecrystal-font-v5") format("truetype");
        font-weight: 400;
        font-style: normal;
    }
    .battle-tower-page,
    .battle-tower-page * {
        font-family: "PokeCrystalInline", "PokeCrystal", monospace !important;
        font-weight: 400 !important;
    }
</style>
{% endblock %}

{% block content %}
<div class="battle-tower-page">
    <h1 class="trade-corner-title">&#xFF22;&#xFF21;&#xFF34;&#xFF34;&#xFF2C;&#xFF25;&#x3000;&#xFF34;&#xFF2F;&#xFF37;&#xFF25;&#xFF32;</h1>

    <form class="battle-tower-controls" method="get">
        <div class="battle-control-level">
            <select name="level" class="trade-region-filter" aria-label="Select level" onchange="this.form.submit()">
                {% for level_value in level_options %}
                    <option value="{{ level_value }}"{% if level_value == selected_level %} selected{% endif %}>L:{{ "%d"|format(level_value) }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="battle-control-room">
            <select name="room" class="trade-region-filter" aria-label="Select room" onchange="this.form.submit()">
                {% for room_value in room_options %}
                    <option value="{{ room_value }}"{% if room_value == selected_room %} selected{% endif %}>ROOM:{{ "%03d"|format(room_value) }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="battle-control-zoom">
            <label class="battle-zoom-label" for="battle-zoom-btn-1">Zoom:</label>
            <div class="trade-size-buttons battle-zoom-buttons" role="group" aria-label="Battle Tower zoom">
                <button id="battle-zoom-btn-1" class="trade-size-btn battle-zoom-btn" type="button" data-battle-zoom="1" aria-pressed="true">1x</button>
                <button class="trade-size-btn battle-zoom-btn" type="button" data-battle-zoom="2" aria-pressed="false">2x</button>
            </div>
        </div>

        <div class="battle-honor-roll-label">HONOR ROLL</div>
    </form>

    <div class="battle-table-shell">
        <div class="battle-table-grid" data-bt-table-wrap>
            <div class="battle-table-panel" data-bt-primary>
                <table class="battle-honor-table">
                    <thead>
                        <tr>
                            <th>ROOM LEADER</th>
                            <th>POK&eacute;MON</th>
                            <th>MESSAGE</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for leader in leaders %}
                            <tr class="bt-row">
                                <td class="bt-leader-cell">
                                    <div class="bt-leader-subcols">
                                        <div class="bt-leader-sprite-col">
                                            <img class="bt-trainer-sprite" src="{{ leader.sprite_path }}" alt="{{ leader.trainer_class }}" loading="lazy">
                                        </div>
                                        <div class="bt-leader-name-col">
                                            <div class="bt-trainer-class">{{ leader.trainer_class }}</div>
                                            <div class="bt-player-name">{{ leader.player_name }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="bt-pokemon-cell">
                                    <ul class="bt-pokemon-list">
                                        {% for pokemon_name in leader.pokemon_names %}
                                            <li>{{ pokemon_name }}</li>
                                        {% endfor %}
                                    </ul>
                                </td>
                                <td class="bt-message-cell">
                                    <div class="bt-message-box">{{ leader.message }}</div>
                                </td>
                            </tr>
                        {% endfor %}

                        {% if leaders is empty %}
                            <tr class="bt-empty-row">
                                <td colspan="3" class="crystal-empty-message">No Trainers found.</td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>

            <div class="battle-table-panel" data-bt-secondary hidden>
                <table class="battle-honor-table">
                    <thead>
                        <tr>
                            <th>ROOM LEADER</th>
                            <th>POK&eacute;MON</th>
                            <th>MESSAGE</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block body %}
<script>
(() => {
    "use strict";

    function findSideBackgroundAnchor() {
        return document.querySelector(
            "header.navbar.container-xxl, header.navbar, main#content.container-xxl, #content.container-xxl, .container-xxl"
        );
    }

    function applyHonorRollSideBackgroundVars() {
        const anchor = findSideBackgroundAnchor();
        if (!anchor) {
            return;
        }
        const rect = anchor.getBoundingClientRect();
        const sideLeft = Math.max(0, Math.round(rect.left));
        const sideRight = Math.max(0, Math.round(window.innerWidth - rect.right));
        document.documentElement.style.setProperty("--trade-corner-nav-side-left", `${sideLeft}px`);
        document.documentElement.style.setProperty("--trade-corner-nav-side-right", `${sideRight}px`);
    }

    function initHonorRollSideBackgrounds() {
        document.body.classList.add("honor-roll-theme");
        applyHonorRollSideBackgroundVars();
        window.addEventListener("resize", applyHonorRollSideBackgroundVars, { passive: true });
        window.addEventListener("load", applyHonorRollSideBackgroundVars, { passive: true });
        if (document.fonts && typeof document.fonts.ready === "object") {
            document.fonts.ready.then(applyHonorRollSideBackgroundVars);
        }
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initHonorRollSideBackgrounds);
    } else {
        initHonorRollSideBackgrounds();
    }
})();
</script>
<script>
(() => {
    const tableWrap = document.querySelector("[data-bt-table-wrap]");
    if (!tableWrap) {
        return;
    }

    const primaryPanel = tableWrap.querySelector("[data-bt-primary]");
    const secondaryPanel = tableWrap.querySelector("[data-bt-secondary]");
    if (!primaryPanel || !secondaryPanel) {
        return;
    }

    const primaryBody = primaryPanel.querySelector("tbody");
    const secondaryBody = secondaryPanel.querySelector("tbody");
    if (!primaryBody || !secondaryBody) {
        return;
    }

    const sourceRows = Array.from(primaryBody.querySelectorAll("tr.bt-row"));
    const pageNode = document.querySelector(".battle-tower-page");
    if (sourceRows.length === 0) {
        secondaryPanel.hidden = true;
        return;
    }

    const rowMarkup = sourceRows.map((row) => row.outerHTML);

    const makeRow = (markup) => {
        const template = document.createElement("template");
        template.innerHTML = markup.trim();
        return template.content.firstElementChild;
    };

    const clearBodies = () => {
        primaryBody.innerHTML = "";
        secondaryBody.innerHTML = "";
    };

    const appendRange = (tbody, start, end) => {
        for (let i = start; i < end; i += 1) {
            const rowNode = makeRow(rowMarkup[i]);
            if (rowNode) {
                tbody.appendChild(rowNode);
            }
        }
    };

    const rebalance = () => {
        clearBodies();
        appendRange(primaryBody, 0, rowMarkup.length);
        secondaryPanel.hidden = true;
        tableWrap.classList.remove("is-split");

        const zoomMode = pageNode ? String(pageNode.getAttribute("data-battle-zoom") || "1") : "1";
        if (zoomMode !== "1") {
            return;
        }

        const availableHeight = Math.max(
            220,
            window.innerHeight - primaryPanel.getBoundingClientRect().top - 20
        );

        if (primaryPanel.offsetHeight <= availableHeight) {
            return;
        }

        clearBodies();
        let splitIndex = rowMarkup.length;
        for (let i = 0; i < rowMarkup.length; i += 1) {
            const rowNode = makeRow(rowMarkup[i]);
            if (!rowNode) {
                continue;
            }
            primaryBody.appendChild(rowNode);
            if (primaryPanel.offsetHeight > availableHeight) {
                primaryBody.removeChild(primaryBody.lastElementChild);
                splitIndex = i;
                break;
            }
        }

        if (splitIndex <= 0 || splitIndex >= rowMarkup.length) {
            splitIndex = Math.ceil(rowMarkup.length / 2);
            clearBodies();
            appendRange(primaryBody, 0, splitIndex);
        }

        appendRange(secondaryBody, splitIndex, rowMarkup.length);

        const shouldSplit = secondaryBody.children.length > 0;
        secondaryPanel.hidden = !shouldSplit;
        tableWrap.classList.toggle("is-split", shouldSplit);
    };

    let resizeTimer = null;
    window.addEventListener("resize", () => {
        if (resizeTimer) {
            clearTimeout(resizeTimer);
        }
        resizeTimer = setTimeout(rebalance, 120);
    });

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", rebalance);
    } else {
        rebalance();
    }
})();
</script>
<script>
(() => {
    const STORAGE_KEY = "reon_battle_tower_zoom";
    const page = document.querySelector(".battle-tower-page");
    const buttons = Array.from(document.querySelectorAll(".battle-zoom-btn[data-battle-zoom]"));
    if (!page || buttons.length === 0) {
        return;
    }

    const clamp = (value) => String(value) === "2" ? "2" : "1";

    const setActive = (zoom) => {
        buttons.forEach((button) => {
            const active = button.getAttribute("data-battle-zoom") === zoom;
            button.classList.toggle("is-active", active);
            button.setAttribute("aria-pressed", active ? "true" : "false");
        });
    };

    const applyZoom = (rawZoom) => {
        const zoom = clamp(rawZoom);
        page.setAttribute("data-battle-zoom", zoom);
        setActive(zoom);
        window.setTimeout(() => {
            window.dispatchEvent(new Event("resize"));
        }, 0);
        return zoom;
    };

    const initialZoom = applyZoom(localStorage.getItem(STORAGE_KEY) || "1");
    localStorage.setItem(STORAGE_KEY, initialZoom);

    buttons.forEach((button) => {
        button.addEventListener("click", () => {
            const zoom = applyZoom(button.getAttribute("data-battle-zoom") || "1");
            localStorage.setItem(STORAGE_KEY, zoom);
        });
    });
})();
</script>
{% endblock %}






